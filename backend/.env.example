# backend/.env 를 만들 때 참고하는 템플릿. 실제 .env는 커밋하지 않는다.
#
# 개발(dev): 기존 au_test_system.db(seed/demo 데이터)를 그대로 가리킨다 — start.bat이 이 .env를 읽는다.
# 운영(prod): start-prod.bat이 이 값들을 환경변수로 직접 오버라이드하므로 .env는 관여하지 않는다.
#   운영 DB 경로는 start-prod.bat 안에서만 관리한다 (실데이터 파일 경로를 이 템플릿에 남기지 않기 위함).

ENVIRONMENT=development
DATABASE_URL=sqlite:///E:/03. Job/00. Claude Code/au-test-system/backend/au_test_system.db
